        <!-- Welcome -->
        <mxCell id="welcome" value="Welcome&#10;&quot;Welcome to my Weekly Payroll program!!&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#000;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="90" width="150" height="60" as="geometry"/>
        </mxCell>
        
