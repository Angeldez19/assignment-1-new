          <mxGeometry x="300" y="450" width="150" height="60" as="geometry"/>
        </mxCell>
        
        <!-- Do Calculations -->
        <mxCell id="calc" value="Do Calculations&#10;grosspayUSD = hours * rate&#10;federalTax = grosspay * withholding&#10;netPay = grosspay - federalTax" style="rect;whiteSpace=wrap;html=1;fillColor=#DDA0DD;strokeColor=#000;strokeWidth=2;" vertex="1" parent="1">
